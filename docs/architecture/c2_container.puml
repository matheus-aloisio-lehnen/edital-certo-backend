@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title "C2: Container Diagram - Edital Certo"

Person(user, "Usuário", "Cliente final")
Person(ops, "Operação / Admin", "Opera a stack local e as rotinas de backup")

System_Ext(cloudflare, "Cloudflare", "DNS, SSL e Tunnel")
System_Ext(ai_api, "Gemini / ChatGPT API", "APIs externas para análises e IA")
System_Ext(gcp_files, "GCP Bucket (Arquivos)", "Object storage dos arquivos enviados")
System_Ext(gcp_backup, "GCP Bucket (Backups)", "Recebe backup diário e artefatos de recuperação")
System_Ext(cold_db, "PostgreSQL Cold Standby", "Banco desligado na nuvem, ligado só em restore")

System_Boundary(local_stack, "Infraestrutura Local") {
    Container(site, "Site", "Angular", "Site público/marketing")
    Container(frontend, "Frontend", "Angular", "Aplicação autenticada do usuário")
    Container(tunnel, "Cloudflare Tunnel", "cloudflared", "Exposição segura dos serviços locais")

    Container(api, "Backend", "NestJS Monolith", "API principal, autenticação, domínio, upload, billing e orquestração")
    Container(queue_processor, "Queue Processor", "NestJS", "Consome mensagens do RabbitMQ e faz a ponte entre backend e worker via REST")
    Container(worker, "Worker", "Go", "Extrai texto, chama IA, gera embeddings e vetoriza no PostgreSQL")

    ContainerDb(db, "PostgreSQL", "PostgreSQL", "Banco transacional principal e armazenamento vetorial")
    ContainerDb(redis, "Redis", "Redis", "Cache e suporte de performance do backend")
    Container(rabbitmq, "RabbitMQ", "Broker", "Canal assíncrono de publicação de mensagens")
    Container(backup_job, "Postgres Backup Job", "Cron / Scripts", "Gera backup diário do PostgreSQL e sincroniza para o bucket")
}

Rel(user, cloudflare, "Acessa os domínios públicos", "HTTPS")
Rel(cloudflare, tunnel, "Encaminha tráfego", "Cloudflare Tunnel")
Rel(tunnel, site, "Expõe site público", "HTTP")
Rel(tunnel, frontend, "Expõe aplicação web", "HTTP")
Rel(tunnel, api, "Expõe API", "HTTP")

Rel(frontend, api, "Consome API", "HTTPS / JSON")
Rel(site, api, "Integra formulários e fluxos públicos quando necessário", "HTTPS / JSON")

Rel(api, db, "Lê e grava dados de negócio", "SQL")
Rel(api, redis, "Usa cache", "Redis")
Rel(api, gcp_files, "Faz upload dos arquivos", "HTTPS")
Rel(api, rabbitmq, "Publica mensagens", "AMQP")

Rel(worker, rabbitmq, "Publica status e eventos de processamento", "AMQP")
Rel(queue_processor, rabbitmq, "Consome mensagens", "AMQP")
Rel(queue_processor, worker, "Dispara processamento e ações do worker", "HTTP / REST")
Rel(queue_processor, api, "Notifica o backend sobre o resultado do processamento", "HTTP / REST")

Rel(worker, gcp_files, "Baixa arquivos para processar", "HTTPS")
Rel(worker, ai_api, "Executa extração/IA/embeddings", "HTTPS")
Rel(worker, db, "Grava vetores e metadados processados", "SQL")

Rel(backup_job, db, "Executa backup diário", "pg_dump / base backup")
Rel(backup_job, gcp_backup, "Sincroniza backup diário e artefatos de recuperação", "HTTPS")
Rel(gcp_backup, cold_db, "Fonte para restore em emergência", "Backup / Restore")
Rel(ops, cold_db, "Liga apenas quando necessário", "Operação manual")

@enduml
