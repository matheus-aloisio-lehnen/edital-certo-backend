@startuml
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false

title "C4: Code Diagram - Fluxo de Ingestão e Processamento Assíncrono"

package "Backend / NestJS" {
  class HttpController
  class UploadFileUseCase
  class StorageService
  class RabbitmqPublisher
  class Logger
  class Metrics
  class Tracer
}

package "Queue Processor / NestJS" {
  class QueueMessageHandler
  class WorkerHttpClient
  class BackendHttpClient
}

package "Worker / Go" {
  class WorkerApi
  class FileDownloader
  class TextExtractor
  class EmbeddingService
  class VectorRepository
  class WorkerRabbitPublisher
}

database "PostgreSQL" as Postgres
queue "RabbitMQ" as Rabbit
cloud "GCP Bucket" as Bucket
cloud "Gemini / ChatGPT API" as AI

HttpController --> UploadFileUseCase : inicia processamento
UploadFileUseCase --> StorageService : envia arquivo
UploadFileUseCase --> RabbitmqPublisher : publica job
UploadFileUseCase --> Logger : log
UploadFileUseCase --> Metrics : métricas
UploadFileUseCase --> Tracer : span

StorageService --> Bucket : upload
RabbitmqPublisher --> Rabbit : publish

Rabbit --> QueueMessageHandler : consume
QueueMessageHandler --> WorkerHttpClient : repassa job
QueueMessageHandler --> BackendHttpClient : notifica backend quando necessário

WorkerHttpClient --> WorkerApi : POST /process
WorkerApi --> FileDownloader : baixa arquivo
FileDownloader --> Bucket : download
WorkerApi --> TextExtractor : extrai texto
WorkerApi --> EmbeddingService : gera embeddings
EmbeddingService --> AI : chamada externa
WorkerApi --> VectorRepository : persiste resultado
VectorRepository --> Postgres : insert/update
WorkerApi --> WorkerRabbitPublisher : publica status
WorkerRabbitPublisher --> Rabbit : publish

Rabbit --> QueueMessageHandler : status / conclusão
QueueMessageHandler --> BackendHttpClient : atualiza backend

note right of QueueMessageHandler
  Backend e Worker apenas publicam no RabbitMQ.
  O Queue Processor é quem consome
  e faz a ponte via REST entre os dois lados.
end note

note bottom of Postgres
  Backup diário é sincronizado para bucket GCP.
  Um PostgreSQL cold standby pode ser ligado
  apenas em cenários de restauração.
end note

@enduml
