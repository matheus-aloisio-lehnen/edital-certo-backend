// ============================================================
// MODULE: CACHE (REDIS)
// Estrutura de chaves voláteis para Sessão e Quotas
// ============================================================

Table cache_session_control {
  key varchar [pk, note: 'Ex: access:active:{userID}']
  value uuid [note: 'ID da Sessão (UUID) que detém o acesso titular']
  ttl integer [note: 'Mesmo TTL do Refresh Token']

  Note: 'Controla a Regra de Sessão Única (Single Session)'
}

Table cache_session_takeover {
  key varchar [pk, note: 'Ex: access:takeover:{userID}']
  value uuid [note: 'ID da Sessão (UUID) candidata a derrubar a titular']
  ttl integer [note: 'Fixo: 15 minutos (constantsshared.FifteenMinutes)']
}

Table cache_session_registry {
  key varchar [pk, note: 'Ex: access:registry:{sessionID}']
  value varchar [note: 'Status da Sessão: ACTIVE ou PENDING']
  ttl integer
}

Table cache_quota_usage {
  key varchar [pk, note: 'Ex: quota:usage:{tenantID}:{quotaKey}:{period}']
  value bigint [note: 'Contador de uso atual (Incr/Decr)']
  ttl integer [note: 'Janela de Reset: Mês atual + margem de segurança']

  Note: 'Fonte primária para QuotaUsageService antes do Sync para o DB'
}

