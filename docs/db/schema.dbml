// ============================================================
// MODULE: PRODUCT
// Responsável por Planos, Preços, Quotas e Permissões
// ============================================================

Table plan {
  id integer [pk, increment]
  name varchar(100) // Ex: Free, Básico, Pro, Enterprise
  key varchar(60) [unique, note: 'FREE, BASIC, PRO, ENTERPRISE, PARTNER']
  is_active boolean [default: true]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table price {
  id integer [pk, increment]
  plan_id integer [ref: > plan.id]
  cycle varchar(30) [note: 'MONTHLY, YEARLY']
  value bigint [note: 'Valor em centavos']
  is_active bool [default: true]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (plan_id, cycle, is_active) [unique]
  }
}

Table feature {
  id integer [pk, increment]
  plan_id integer [ref: > plan.id]

  key varchar(100) [note: 'Ex: notice_library, write_drafts, evaluate_project, ai_helper, calendar, multi_user']
  name varchar(150)
  enabled bool [default: false]
  is_active bool [default: true]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (plan_id, key) [unique]
  }
}

// 1. Camada de Rastro (Audit Log / Tracking Individual)
Table feature_usage_events {
  id bigint [pk, increment]
  tenant_id integer [ref: > tenants.id]
  user_id integer [ref: > users.id, note: 'Quem realizou a ação']
  feature_id integer [ref: > features.id]
  amount integer [note: 'Quantidade consumida']
  used_at timestamptz [default: `now()`]

  Note: 'Tabela de insert-only para histórico e auditoria detalhada.'
}

// 2. Camada de Performance (Consolidado para Validação Rápida)
Table feature_usage_cache {
  id integer [pk, increment]
  tenant_id integer [ref: > tenants.id]
  feature_id integer [ref: > features.id]
  period varchar(7) [note: 'Formato YYYY-MM ou STATIC']
  amount integer [default: 0, note: 'Soma acumulada do período']
  updated_at timestamptz

  indexes {
    (tenant_id, feature_id, period) [unique]
  }

  Note: 'Tabela de update para evitar SUM() pesado no banco.'
}

Table quota {
  id integer [pk, increment]
  feature_id integer [ref: > feature.id, unique]

  limit bigint [default: 0, note: '-1 para ilimitado']
  reset_window varchar(20) [default: 'MONTHLY', note: 'MONTHLY, YEARLY, STATIC']
  is_active bool [default: true]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

// ============================================================
// MODULE: COMMUNICATION
// Responsável por Alertas, Notificações e Confirmações de Leitura
// Esse alert nao deveria ser alert. deveria ser comunicação com cliente. São eles: Aviso de manutenção, Aviso de marketing em modal, Aviso de atraso, talvez changelog
// ============================================================

Table alert {
  id integer [pk, increment]
  title varchar(200) [not null]
  subtitle varchar(200)
  message text [not null]
  type varchar(30) [not null, note: 'MKT, SYSTEM, MODAL, IMAGE']
  is_active boolean [default: false, note: 'Controle de veiculação (nasce inativo)']

  // Call to Action (CTA) - Opcionais conforme lógica de domínio
  btn_type varchar(20) [note: 'FILLED | OUTLINED']
  btn_text varchar(100)
  url text [note: 'Link de redirecionamento (CTA)']

  image_url text [note: 'Obrigatório para o tipo IMAGE']
  toolbar_color varchar(15) [note: 'Cor em Hexadecimal (ex: #FFFFFF)']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table alert_ack {
  id integer [pk, increment]
  user_id integer [ref: > user.id, not null]
  alert_id integer [ref: > alert.id, not null]
  read_at timestamptz [default: `now()`, note: 'Data de confirmação da leitura (Imutável)']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (user_id, alert_id) [unique, note: 'Trava: Impede duplicidade de leitura para o mesmo alerta']
  }
}

Enum changelog_type {
  feature
  improvement
  fix
  announcement
}

Table changelog_release {
  id integer [pk, increment]
  version varchar(20)
  html text
  published_at timestamp [not null]
  is_published boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp

  Note: 'Cada registro representa uma release completa do changelog. content guarda title, html por idioma.'
}

