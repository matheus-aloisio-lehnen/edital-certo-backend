// ============================================================
// MODULE: ANALYSIS
// Responsável por Draft, Evaluation, File, Job, NoticeSummary, NoticeUser
// ============================================================

Table draft {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  user_id integer [ref: > user.id]
  title varchar(255)
  funding_id varchar(255)
  category varchar(255)
  target varchar(255) // public alvo
  start_submission varchar(255)
  end_submission varchar(255)
  content_gz bytea
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz
  indexes {
    (tenant_id, user_id)
  }
}

Table evaluation {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  user_id integer [ref: > user.id]
  notice_title varchar(255)
  project_title varchar(255)
  overall_score integer
  strengths text[]
  weaknesses text[]
  suggestions text[]
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz
}

Table evaluation_score {
  id integer [pk, increment]
  evaluation_id integer [ref: > evaluation.id]
  name varchar(255)
  score integer
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz
}

Table file {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id, note: 'NULL para arquivos globais']
  user_id integer [ref: > user.id]
  content_hash varchar(255) [note: 'SHA256 para evitar duplicidade']
  kind varchar(20) // PROJECT | NOTICE | DRAFT | EVALUATE
  display_name varchar(255) // Nome original (ex: edital.pdf)
  storage_name varchar(255)// Nome físico no bucket (ex: 20260204-hash.pdf)
  folder varchar(255) // Pasta do storage
  path varchar(255) // Snapshot completo (Folder + StorageName)
  extension varchar(10) // Já deve vir tratada da borda (.pdf, .png, etc)
  size_bytes integer
  is_public boolean [default: false]
  url text
  expires_at timestamptz
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz
  indexes {
    (tenant_id, content_hash)
    path
    kind
  }
}

Table notice_summary {
  id integer [pk, increment]
  file_id integer [ref: - file.id, unique]
  title varchar(255) [note: 'Título global do edital']
  content bytea
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz
}

Table notice_user {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  user_id integer [ref: > user.id]
  notice_summary_id integer [ref: > notice_summary.id]
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz
  indexes {
    (user_id, notice_summary_id) [unique]
  }
}

Table job {
  id varchar(255) [pk]
  tenant_id integer [ref: > tenant.id]
  user_id integer [ref: > user.id]
  kind varchar(50)
  status varchar(20)
  file_names text[]
  total_bytes integer
  error_message text
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz
}

// ============================================================
// MODULE: ACCESS
// Responsável por Identidade, Usuários e Sessões
// ============================================================

Table user {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  name varchar(200)
  email varchar(150) [unique]
  password varchar(100) [note: 'Hash da senha (vo.Password)']
  role varchar(20) [note: 'OWNER ou MEMBER']
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table session {
  id uuid [pk] // Gerado no domínio via uuid.New().String()
  user_id integer [ref: > user.id, not null]
  tenant_id integer [ref: > tenant.id, not null]
  refresh_token varchar(150) [unique, note: 'Token aleatório para rotação']
  status varchar(20) [note: 'PENDING ou ACTIVE']
  ip varchar(45) [note: 'Suporte a IPv4 e IPv6']
  user_agent text
  device varchar(150) [note: 'Ex: Chrome on Windows, iPhone App']
  expires_at timestamptz [not null]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz [note: 'Gerencia a revogação (Soft Delete)']

  Note: 'Gerenciamento de sessões com suporte a Single Session e Refresh Token Rotation'
}

// ============================================================
// MODULE: BILLING
// Responsável por Tenant, Assinatura, Entitlements e Cobrança
// ============================================================



Table identity {
  id integer [pk, increment]
  tenant_id integer [ref: - tenant.id, unique]

  phone varchar(40)
  document varchar(50)
  document_country varchar(2)
  person_type varchar(20) // PF, PJ
  sector_source varchar(100)

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

Table address {
  id integer [pk, increment]
  tenant_id integer [ref: - tenant.id, unique]

  zip_code varchar(20)
  street varchar(200)
  number varchar(30)
  complement varchar(150)
  city varchar(100)
  state varchar(50)
  country_code varchar(2) [default: 'BR']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

Table tenant_feature {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  feature_id integer [ref: > feature.id]

  enabled boolean [default: true]
  is_active boolean [default: true]

  starts_at timestamptz
  ends_at timestamptz

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (tenant_id, feature_id) [unique]
  }
}

Table tenant_quota {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  quota_id integer [ref: > quota.id]

  limit bigint [default: 0, note: '-1 para ilimitado']
  is_active boolean [default: true]

  starts_at timestamptz
  ends_at timestamptz

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (tenant_id, quota_id) [unique]
  }
}

Table quota_consumption {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  quota_id integer [ref: > quota.id]

  period date [note: 'Normalizado: primeiro dia do período']
  used bigint [default: 0]
  limit bigint [default: 0, note: 'Snapshot do limite aplicado no período']

  last_sync_at timestamptz [default: `now()`]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz

  indexes {
    (tenant_id, quota_id, period) [unique]
  }
}


Table tenant {
  id integer [pk, increment]
  name varchar(200)
  email varchar(150) [unique]

  // Espelho operacional do plano atual da assinatura.
  // Usado para resolver feature/quota sem depender de join com subscription.
  plan_id integer [ref: > plan.id]

  phone varchar(40)
  document varchar(50)
  sector_source varchar(100)
  city varchar(100)
  state varchar(50)
  country_code varchar(2) [default: 'BR']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

Table subscription {
  id integer [pk, increment]
  tenant_id integer [ref: - tenant.id, unique]

  plan_id integer [ref: > plan.id, note: 'Fonte contratual do plano; tenant.plan_id deve espelhar este valor']
  price_id integer [ref: > price.id]

  plan_name varchar(100)
  plan_key varchar(60)

  invoice_email varchar(150)
  status varchar(30) [default: 'ACTIVE', note: 'ACTIVE, OVERDUE, SUSPENDED, CANCELLED']

  external_customer_id varchar(80) [unique, note: 'ID do cliente no Asaas']
  external_subscription_id varchar(100) [unique, note: 'ID da assinatura no Asaas']

  billing_cycle varchar(30) [note: 'MONTHLY, YEARLY']
  billing_day integer
  next_due_date timestamptz

  seats integer [default: 1]
  unit_price bigint [note: 'Valor unitario em centavos']
  final_price bigint [note: 'Valor final atual da assinatura em centavos']

  overdue_invoice_id integer [ref: > invoice.id, null]
  overdue_since timestamptz
  block_at timestamptz

  starts_at timestamptz
  ends_at timestamptz
  cancelled_at timestamptz

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

Table subscriptionChange {
  id integer [pk, increment]
  subscriptionId integer [ref: > subscription.id]
  tenantId integer [ref: > tenant.id]

  type varchar(30) [note: 'onboarding, upgrade, downgrade, seat_change, cancel, winback']
  reason varchar(255)

  actorUserId integer [ref: > user.id, null]

  fromPlanId integer [ref: > plan.id, null]
  fromPlanName varchar(100)
  fromPlanKey varchar(60)
  fromPriceId integer [ref: > price.id, null]
  fromCycle varchar(30) [note: 'monthly, yearly']
  fromSeats integer
  fromUnitPrice bigint
  fromFinalPrice bigint
  fromMrr bigint

  toPlanId integer [ref: > plan.id, null]
  toPlanName varchar(100)
  toPlanKey varchar(60)
  toPriceId integer [ref: > price.id, null]
  toCycle varchar(30) [note: 'monthly, yearly']
  toSeats integer
  toUnitPrice bigint
  toFinalPrice bigint
  toMrr bigint

  mrrVariation bigint [note: 'to_mrr - from_mrr']
  effectiveAt timestamptz [default: `now()`]
  createdAt timestamptz [default: `now()`]
}

Table invoice {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  subscription_id integer [ref: > subscription.id]

  status varchar(30) // PENDING, PAID, OVERDUE, CANCELLED
  due_date timestamptz
  value bigint // valor em centavos

  external_id varchar(100) [unique, note: 'ID do pagamento no Asaas (pay_...)']
  paid_at timestamptz
  last_event_id varchar(150) [note: 'ID do webhook para deduplicação']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

Table checkout {
  id integer [pk, increment]
  payload jsonb
  status varchar(30)
  createdAt timestamptz [default: `now()`]
  updatedAt timestamptz
  deletedAt timestamptz
}

Table stripe_event {
  id varchar(100) [pk] // evt_xxx
  type varchar(100)
  created_at timestamptz
}

