// PRODUCT

Table feature {
  id integer [pk, increment]
  plan_id integer [ref: > plan.id]

  key varchar(100) [note: 'Ex: LIBRARY, SUMMARY, WRITE, EVALUATE, AI_HELP, CALENDAR, MULTI_USER']
  name varchar(150)
  order integer
  hidden bool [default: true]
  is_active bool [default: false]
  has_quota bool [default: false]
  quota integer [default: 0]
  quota_renewal_cycle varchar(20) [note: 'MONTHLY, YEARLY, STATIC']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (plan_id, key) [unique]
    (plan_id, order) [unique]
  }
}

Table price {
  id integer [pk, increment]
  plan_id integer [ref: > plan.id]

  key varchar(100) [note: 'Ex: FREE_MONTHLY_BRL, START_YEARLY_USD. Ver priceKey no código.']
  currency varchar(3) [note: 'BRL, USD, EUR']
  billing_cycle varchar(30) [note: 'MONTHLY, YEARLY']
  value bigint [note: 'Valor base em centavos']
  is_active bool [default: true, note: 'Apenas um registro ativo por (key, billing_cycle)']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (plan_id)
    (key, billing_cycle)
  }
}

Table discount {
  id integer [pk, increment]
  price_id integer [ref: > price.id]

  key varchar(100) [unique]
  name varchar(100)
  type varchar(20) [note: 'PERCENT, FIXED']
  value bigint [note: 'Percentual inteiro ou valor fixo em centavos']
  strategy varchar(20) [note: 'ONCE, REPEATING, FOREVER']
  cycle integer [null, note: 'Obrigatorio se duration_type = REPEATING']

  starts_at timestamptz
  ends_at timestamptz [null]

  is_active bool [default: true]

  external_coupon_id varchar(100) [null]
  external_promotion_code_id varchar(100) [null]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (price_id)
    (price_id, is_active)
  }
}

Table plan {
  id integer [pk, increment]
  key varchar(50) [unique, not null, note: 'FREE, START, PRO, TEAMS']
  name varchar(100) [not null]
  is_active boolean [not null, default: true]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz

  Note: 'Tabela base de planos. Chaves em UPPERCASE para match com o back-end.'
}

// IDENTITY

Table tenant {
  id integer [pk, increment]
  name varchar(200)

  plan_id integer [ref: > plan.id]

  phone varchar(40)
  document varchar(50)
  sector varchar(100)
  city varchar(100)
  state varchar(50)
  country_code varchar(2) [default: 'BR']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    plan_id
    document
    created_at
  }
}

Table tenant_feature {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  feature_id integer [ref: > feature.id]

  is_active boolean [default: true]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (tenant_id, feature_id) [unique]
    (tenant_id)
    (feature_id)
  }

  Note: 'Override por tenant para ativar ou desativar features independentemente do plano.'
}

Table feature_usage {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  feature_id integer [ref: > feature.id]

  period varchar(20) [note: 'Ex: YYYY-MM, YYYY ou STATIC']
  amount integer [default: 0, note: 'Soma acumulada do periodo']

  created_at timestamptz [default: `now()`]
  updated_at timestamptz

  indexes {
    (tenant_id, feature_id, period) [unique]
    (tenant_id)
    (feature_id)
  }

  Note: 'Acumulado operacional por periodo.'
}

Table feature_usage_event {
  id bigint [pk, increment]

  tenant_id integer [ref: > tenant.id]
  user_id integer [ref: > user.id, null]
  feature_id integer [ref: > feature.id]

  amount integer [note: 'Quantidade consumida']
  period varchar(20) [note: 'Ex: YYYY-MM, YYYY ou STATIC']

  used_at timestamptz [default: `now()`]
  created_at timestamptz [default: `now()`]

  indexes {
    (tenant_id, feature_id, period)
    (tenant_id, user_id, used_at)
    (feature_id, used_at)
    (used_at)
  }

  Note: 'Histórico detalhado de consumo por feature.'
}

Table user {
  id integer [pk, increment]
  tenant_id integer [ref: > tenant.id]
  name varchar(200)
  email varchar(150) [unique]
  password varchar(100)
  role varchar(20) [note: 'owner, member']
  lang_code varchar(10) [default: 'pt', note: 'pt, en, es']
  avatar_id integer [null]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz

  indexes {
    tenant_id
    email
    (tenant_id, email) [unique]
    deleted_at
  }
}

Table session {
  id uuid [pk]
  user_id integer [ref: > user.id, not null]
  tenant_id integer [ref: > tenant.id, not null]
  refresh_token varchar(150) [unique]
  status varchar(20)
  ip varchar(45)
  user_agent text
  device varchar(150)
  expires_at timestamptz [not null]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz

  indexes {
      user_id
      tenant_id
      refresh_token [unique]
      expires_at
      (user_id, status)
    }
  Note: 'Gerenciamento de sessões com suporte a Single Session e Refresh Token Rotation'
}

// BILLING

Table subscription {
  id integer [pk, increment]
  tenant_id integer [ref: - tenant.id, unique]

  plan_id integer [ref: > plan.id]
  price_id integer [ref: > price.id]

  plan_name varchar(100)
  plan_key varchar(60)

  invoice_email varchar(150)
  status varchar(30) [default: 'ACTIVE']

  external_customer_id varchar(100) [unique]
  external_subscription_id varchar(100) [unique]

  billing_cycle varchar(30)
  billing_day integer
  next_due_date timestamptz
  seats integer [default: 1]
  currency varchar(3)
  discount_type varchar(20) [null]
  discount_value bigint [null]
  unit_price bigint
  price_with_discount bigint
  total_price bigint
  total_with_discount bigint

  overdue_invoice_id integer [null]
  overdue_since timestamptz
  block_at timestamptz

  starts_at timestamptz
  ends_at timestamptz

  created_at timestamptz [default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    (tenant_id) [unique]
    (external_subscription_id) [unique]
    (external_customer_id) [unique]
    (status)
    (next_due_date)
    (plan_id)
    (price_id)
  }
}

Table subscription_change {
  id integer [pk, increment]
  subscription_id integer [ref: > subscription.id]
  tenant_id integer [ref: > tenant.id]

  type varchar(30) [note: 'ONBOARDING, UPGRADE, DOWNGRADE, SEAT_CHANGE, CANCEL, WINBACK, DISCOUNT_APPLIED, DISCOUNT_EXPIRED, RENEWAL']
  reason varchar(255) [null]

  actor_fullname varchar(255)

  from_plan_id integer [ref: > plan.id, null]
  to_plan_id integer [ref: > plan.id, null]

  from_plan_name varchar(100) [null]
  to_plan_name varchar(100) [null]

  from_plan_key varchar(60) [null]
  to_plan_key varchar(60) [null]

  from_price_id integer [ref: > price.id, null]
  to_price_id integer [ref: > price.id, null]

  from_discount_id integer [ref: > discount.id, null]
  to_discount_id integer [ref: > discount.id, null]

  from_billing_cycle varchar(30) [null]
  to_billing_cycle varchar(30) [null]

  from_currency varchar(3) [null]
  to_currency varchar(3) [null]

  from_seats integer [null]
  to_seats integer [null]

  from_unit_price bigint [null]
  to_unit_price bigint [null]

  from_total_price bigint [null]
  to_total_price bigint [null]

  from_total_with_discount bigint [null]
  to_total_with_discount bigint [null]

  effective_at timestamptz [default: `now()`]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz

  indexes {
    (subscription_id)
    (tenant_id)
    (effective_at)
    (type)
  }
}


// NOTIFICATIONS

Table changelog {
  id integer [pk, increment]
  version varchar(20) [not null]
  title varchar(255) [not null]
  html text [not null]
  is_published boolean [not null, default: false]
  published_at timestamptz

  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz

  indexes {
    version [unique]
    is_published
    published_at
  }

  Note: 'Registro de atualizações e novas funcionalidades do sistema'
}

Table broadcast {
  id integer [pk, increment]
  type varchar(10) [not null]
  severity varchar(15) [not null]
  priority integer [not null]
  content text [not null]
  is_active boolean [not null, default: false]
  expires_at timestamptz

  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz

  indexes {
    is_active
    expires_at
    (is_active, expires_at)
  }

  Note: 'Centraliza as comunicações do sistema'
}

Table user_broadcast_ack {
  id integer [pk, increment]
  user_id integer [not null, ref: > user.id]
  broadcast_id integer [not null, ref: > broadcast.id]
  read_at timestamptz [not null, default: `now()`]

  created_at timestamptz [default: `now()`]
  updated_at timestamptz

  indexes {
    (user_id, broadcast_id) [unique]
  }

  Note: 'Rastreio de leitura individual'
}